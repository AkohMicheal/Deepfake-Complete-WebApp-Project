# ==============================================================================
# Dual-Stream Deepfake API — Environment Configuration
# ==============================================================================
# Copy this file to `.env` and customize for your environment.
#
#   cp .env.example .env
#
# All variables have sensible defaults for local development.
# See app/config.py for the full list of supported settings.
# ==============================================================================

# --- CORS ---
# Comma-separated list of allowed origins (update for production).
CORS_ORIGINS=["http://localhost:3000"]

# --- Model Source ---
# HuggingFace repository containing the model weights.
HUGGINGFACE_REPO_ID=AkohTech/deepfake-dual-stream-model
HUGGINGFACE_FILENAME=hybrid_model.h5

# Uncomment to load from a local file instead of HuggingFace:
# LOCAL_MODEL_PATH=./hybrid_model.h5

# --- Upload Constraints ---
MAX_UPLOAD_BYTES=52428800

# --- Inference Parameters ---
INPUT_SIZE=224
FAKE_THRESHOLD=50.0
CRITICAL_THRESHOLD=90.0
MAX_SAMPLE_FRAMES=8

# --- Logging ---
LOG_LEVEL=INFO
